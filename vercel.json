{
  "version": 2,
  "cleanUrls": true,
  "functions": {
    "api/chat.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/create-opportunity.js": {
      "maxDuration": 30
    },
    "api/psi.js": {
      "maxDuration": 45
    },
    "api/generate-report.js": {
      "maxDuration": 120
    }
  },
  "rewrites": [
    { "source": "/r/:id", "destination": "/api/get-generated-report?id=:id" },
    { "source": "/audit/:id", "destination": "/website-audit.html?id=:id" },
    { "source": "/reports/:slug", "destination": "/reports/:slug.html" }
  ]
}
