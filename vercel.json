{
  "version": 2,
  "cleanUrls": true,
  "functions": {
    "api/chat.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/create-opportunity.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/r/:id", "destination": "/report.html?id=:id" },
    { "source": "/audit/:id", "destination": "/website-audit.html?id=:id" },
    { "source": "/reports/:slug", "destination": "/reports/:slug.html" }
  ]
}
